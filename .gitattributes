# Normalize line endings so working trees on Windows, macOS, and Linux all
# see the same content. Without this, simply opening a file in some Windows
# editors (which auto-CRLF on save) makes git think every line was changed.
#
# Set the default to LF — same as the existing committed history. Existing
# files only fully renormalize after a one-time `git add --renormalize .`
# followed by a commit.

* text=auto eol=lf

# Binary files — keep as-is, never normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.mp3 binary
*.mp4 binary
*.wav binary
*.ogg binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.eot binary
*.zip binary
*.tar binary
*.gz binary
*.7z binary
*.pdf binary
*.jks binary
*.p8 binary
*.p12 binary
*.keystore binary

# Shell scripts must always be LF (Windows would break execution otherwise)
*.sh text eol=lf

# Windows batch files must keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
