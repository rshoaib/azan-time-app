# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# typescript / tsc one-off output dumps (these are dev scratchpads; don't track)
tsc_*.log
tsc_*.txt

# Secrets — service-account keys must never land in git history
google-play-key.json

# Claude Code workspace state (worktrees, settings, agent caches)
.claude/

# generated native folders
/ios
/android
